---
import { siteConfig } from "@/config/site";
---

<footer class="mt-20 border-t border-border bg-card" id="contact">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-8 md:flex-row">
      <div class="flex flex-col items-center gap-2 md:items-start">
        <span class="text-lg font-bold text-foreground">{siteConfig.name}</span>
        <p class="text-sm text-muted-foreground">
          {siteConfig.description}
        </p>
      </div>
      <div class="flex items-center gap-6">
        {
          Object.keys(siteConfig.socialLinks).map((item) => (
            <a
              href={siteConfig.socialLinks[item]}
              target="_blank"
              class="hover:text-primary capitalize"
            >
              {item}
            </a>
          ))
        }
      </div>
    </div>
    <div
      class="mt-8 border-t border-border pt-8 text-center text-xs text-muted-foreground"
    >
      &copy; {new Date().getFullYear()}
      {siteConfig.author}. All rights reserved.
    </div>
  </div>
</footer>
