---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import Hero from "@/components/widgets/Hero.astro";
import Features from "@/components/widgets/Features.astro";
---

<BaseLayout>
  <Hero
    id="home"
    title={`Your DevOps Journey <br class="hidden md:block" /> <span class="bg-linear-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">Starts Here</span>`}
    tagline="Coming Soon..."
    description={`${siteConfig.description}`}
    actions={[
      {
        text: "Check out my Instagram",
        href: "https://github.com/devgelo-labs/astro-starter-pro",
        variant: "primary",
        icon: "lucide:instagram",
      },
      // {
      //   text: "Our Services",
      //   href: "/services",
      //   variant: "secondary",
      //   icon: "lucide:arrow-right",
      //   ariaLabel: "Learn more about our services",
      // },
    ]}
  />
  <Features
    id="about"
    tagline="Features"
    title="What's coming"
    subtitle="Curated high quality DevOps content"
    features={[
      {
        title: "Concise DevOps Guides",
        description:
          "Step‑by‑step tutorials covering CI/CD, Docker, Kubernetes and Terraform.",
        icon: "lucide:book-open",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Handy Cheatsheets",
        description:
          "Quick command references and config snippets you can copy and reuse.",
        icon: "lucide:clipboard",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "Career Guides & Mentorship",
        description:
          "Resume tips, interview prep, and real-world career advice to help you break into DevOps.",
        icon: "lucide:graduation-cap",
        iconClass: "bg-emerald-500/10 text-emerald-400",
      },
      // {
      //   title: "Curated Resources",
      //   description: "Playlists, articles and tools hand-picked to accelerate your learning path.",
      //   icon: "lucide:link",
      //   iconClass: "bg-yellow-500/10 text-yellow-400",
      // },
    ]}
  />
